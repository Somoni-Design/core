generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OWNER
  SUPPLIER
  WAREHOUSE_MANAGER
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum ExpenseType {
  MATERIAL
  WORKER
}

model User {
  id              String     @id @default(uuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  email           String     @unique
  phone           String?    @unique
  fullName        String?
  passwordHash    String?
  role            UserRole?
  status          UserStatus @default(PENDING)
  isEmailVerified Boolean    @default(false)

  expenses   Expense[]
  apartments Apartment[]

  @@map("users")
}

model AuthCode {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  email     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  @@index([email])
  @@map("auth_codes")
}

model Expense {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  title     String
  quantity  Decimal     @default(1) @db.Decimal(12, 2)
  unitPrice Decimal     @default(0) @db.Decimal(12, 2)
  amount    Decimal     @db.Decimal(12, 2)
  spentAt   DateTime
  type      ExpenseType @default(MATERIAL)

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])

  supplierId String
  supplier   User   @relation(fields: [supplierId], references: [id])

  @@index([apartmentId])
  @@index([supplierId])
  @@index([spentAt])
  @@index([type])
  @@map("expenses")
}

model Apartment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String

  supplierId String
  supplier   User   @relation(fields: [supplierId], references: [id])

  expenses Expense[]

  @@index([supplierId])
  @@map("apartments")
}
