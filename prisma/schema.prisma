generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OWNER
  SUPPLIER
  WAREHOUSE_MANAGER
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

model User {
  id              String     @id @default(uuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  phone           String     @unique
  fullName        String?
  passwordHash    String?
  role            UserRole?
  status          UserStatus @default(PENDING)
  isPhoneVerified Boolean    @default(false)

  @@map("users")
}

model AuthCode {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  phone     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  @@index([phone])
  @@map("auth_codes")
}
